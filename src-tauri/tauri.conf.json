{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dais",
  "version": "../package.json",
  "identifier": "org.dais.desktop",
  "build": {
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' app: blob: data:; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src-server/dist/server/_internal/": "_internal/",
      "../src-frontend/dist/": "dist/"
    },
    "externalBin": ["../src-server/dist/server/server"]
  }
}
